	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@openai/codex-sdk": "^0.144.1",
		"@types/node": "^22.15.17",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	}
